<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="cn.geoair.geoairteam.gwc.mapper.gwc.LayerGroupAliasMapper">

    <sql id="tableName">
        tgwc_layer_group_alias
    </sql>
    <sql id="condition">
                <if test="param.id != null and param.id != ''">
                    AND tgwc_layer_group_alias.id = #{param.id}
                </if>
                <if test="param.layerGroupAlias != null and param.layerGroupAlias != ''">
                    AND tgwc_layer_group_alias.layer_group_alias = #{param.layerGroupAlias}
                </if>
                <if test="param.layerString != null and param.layerString != ''">
                    AND tgwc_layer_group_alias.layer_string = #{param.layerString}
                </if>
                <if test="param.remark != null and param.remark != ''">
                    AND tgwc_layer_group_alias.remark = #{param.remark}
                </if>
                <if test="param.wmtsUrl != null and param.wmtsUrl != ''">
                    AND tgwc_layer_group_alias.wmts_url = #{param.wmtsUrl}
                </if>

        <if test="param.andQueryContentIn != null and param.andQueryContentIn.length > 0">
            AND (
            <foreach collection="param.andQueryContentIn" item="str" index="index"   >
                row_to_json(tgwc_layer_group_alias)||'' LIKE '%'|| #{str}||'%'    or
            </foreach>
            1!=1 )
        </if>

                <if test="param.andIdsIn != null and param.andIdsIn.length > 0">
                    AND tgwc_layer_group_alias.id IN
                    <foreach collection="param.andIdsIn" item="id" index="index" open="(" close=")" separator=",">
                        #{id}
                    </foreach>
                </if>

                <if test="param.andIdsNotIn != null and param.andIdsNotIn.length > 0 ">
                    AND tgwc_layer_group_alias.id NOT IN
                    <foreach collection="param.andIdsNotIn" item="id" index="index" open="(" close=")" separator=",">
                        #{id}
                    </foreach>
                </if>

    </sql>


    <sql id="fieldList">
                 tgwc_layer_group_alias.layer_group_alias,
                tgwc_layer_group_alias.layer_string,
                tgwc_layer_group_alias.remark,
                tgwc_layer_group_alias.wmts_url,
                tgwc_layer_group_alias.id
    </sql>
    <select id="searchList" resultType="cn.geoair.geoairteam.gwc.model.gwc.dto.LayerGroupAliasDto">
        SELECT * FROM  <include refid="tableName"></include>
        <where>
            1 = 1
            <include refid="condition"></include>
        </where>
    </select>

</mapper>
