<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="cn.geoair.geoairteam.gwc.mapper.sys.ConfigPropertyMapper">

    <sql id="tableName">
         config_property
    </sql>
    <sql id="condition">
                <if test="param.id != null and param.id != ''">
                    AND  config_property.id = #{param.id}
                </if>
                <if test="param.key != null and param.key != ''">
                    AND  config_property.key = #{param.key}
                </if>
                <if test="param.value != null and param.value != ''">
                    AND  config_property.value = #{param.value}
                </if>
                <if test="param.remark != null and param.remark != ''">
                    AND  config_property.remark = #{param.remark}
                </if>
                <if test="param.updateTime != null">
                    AND  config_property.update_time <![CDATA[>=]]>  #{param.updateTime,jdbcType=TIMESTAMP}
                    AND  config_property.update_time <![CDATA[<=]]> date_add(#{param.updateTime,jdbcType=TIMESTAMP}, date_trunc('day', current_date + interval '1 day'))
                </if>
                <if test="param.groupName != null and param.groupName != ''">
                    AND  config_property.group_name = #{param.groupName}
                </if>

        <if test="param.andQueryContentIn != null and param.andQueryContentIn.length > 0">
            AND (
            <foreach collection="param.andQueryContentIn" item="str" index="index"   >
                row_to_json( config_property)||'' LIKE '%'|| #{str}||'%'    or
            </foreach>
            1!=1 )
        </if>

                <if test="param.andIdsIn != null and param.andIdsIn.length > 0">
                    AND  config_property.id IN
                    <foreach collection="param.andIdsIn" item="id" index="index" open="(" close=")" separator=",">
                        #{id}
                    </foreach>
                </if>

                <if test="param.andIdsNotIn != null and param.andIdsNotIn.length > 0 ">
                    AND  config_property.id NOT IN
                    <foreach collection="param.andIdsNotIn" item="id" index="index" open="(" close=")" separator=",">
                        #{id}
                    </foreach>
                </if>

    </sql>

    <!--   留作备用，不用刻意维护-->
    <resultMap id="BaseResultMap" type="cn.geoair.geoairteam.gwc.model.sys.dto.ConfigPropertyDto">
    </resultMap>
    <sql id="fieldList">
                  config_property.key,
                 config_property.value,
                 config_property.remark,
                 config_property.update_time,
                 config_property.group_name,
                 config_property.id
    </sql>

    <select id="searchList" resultType="cn.geoair.geoairteam.gwc.model.sys.dto.ConfigPropertyDto">
        SELECT * FROM
        <include refid="tableName"></include>
        <where>
            1 = 1
            <include refid="condition"></include>
        </where>
    </select>

</mapper>
