    <backendTimeout>120</backendTimeout>
    <serviceInformation>
        <title>GeoWebCache</title>
        <description>GeoWebCache 是用于 WMS 服务器的高级切片缓存。它支持多种协议和格式，包括 WMS-C、WMTS、KML、谷歌地图和虚拟地球。</description>
        <keywords>
            <string>WFS</string>
            <string>WMS</string>
            <string>WMTS</string>
            <string>GEOWEBCACHE</string>
        </keywords>
        <serviceProvider>
            <providerName>geoairTeam</providerName>
            <providerSite>http://www.geoair.com</providerSite>
            <serviceContact>
                <individualName>geoairTeam</individualName>
                <positionName>team</positionName>
                <addressType>Work</addressType>
                <addressStreet>天安门</addressStreet>
                <addressCity>北京</addressCity>
                <addressAdministrativeArea>中国大陆</addressAdministrativeArea>
                <addressPostalCode>101399</addressPostalCode>
                <addressCountry>中国</addressCountry>
                <phoneNumber>+86 110112119</phoneNumber>
                <faxNumber>+86 110112119</faxNumber>
                <addressEmail>sales@geoair·.com</addressEmail>
            </serviceContact>
        </serviceProvider>
        <fees>NONE</fees>
        <accessConstraints>NONE</accessConstraints>
    </serviceInformation>

