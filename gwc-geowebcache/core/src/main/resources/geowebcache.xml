        <!-- GeoAir封装的 谷歌tms切片使用wmts方式加载
           1. name：图层名称 注意只能是字母
           2. sortkey: 排序的键
           3 loadMethod：加载方式 只有两种加载方式  一种是 http ，一种是 local ，两种方式对应的是两种请求方式，
           第一种是 瓦片部署在 其他的 服务器，我们的geowebcache只做http代理，另一种是瓦片部署在geowebcache所在的服务器，geowebcache使用读取图片的方式进行上图
           4 localPath：切片所在的位置
           5 httpPath：切片远程所在的位置
           6 group ：所在的 组  注意只能是字母
           7 format ：瓦片的后缀


           请求方式：
           该封装暂时只支持单图层的请求方式，请求url示例
            http://192.168.0.110:12307/geowebcache/geoair/xyz/111113-local/wmts
            xyz：代表数据源是 xyz的方式
            111113：代表请求的是 111113这个图层

       只要是你的切片是按照谷歌切片方案进行切图的，这里就可以进行使用wmts方式进行加载
        代码示例
        layer: "111113-local",
        matrixSet: "C",//随意写，因为这个参数对于xyz的请求而言是无意义的
        url: "http://192.168.0.110:12307/geowebcache/geoair/xyz/111113-local/wmts",
        projection: "EPSG:3857",
        maxResolution: "156543.03392800014",  //  谷歌标准切片方案的分辨率
        level: 19,
        origin: [-20037508.342787001, 20037508.342787001],  //  谷歌标准切片方案的切片原点
        extent: ol.proj.get('EPSG:3857').getExtent(), // 谷歌标准切片方案的地图边界范围
           -->

        <tc-tmsLayer>
            <name>111113-local</name>
            <sortkey>3</sortkey>
            <loadMethod>local</loadMethod>
            <localPath>E:\nginx_pxy\0909-qubaibain-xianshu-qubaitu-1.0\{z}\{x}\{y}.png</localPath>
            <group>demo-hgt</group>
        </tc-tmsLayer>


        <tc-tmsLayer>
            <name>zhongguo</name>
            <sortkey>1</sortkey>
            <loadMethod>http</loadMethod>
            <httpPath>http://wuhan.geoair.com.cn:9054/zhongguo0-12/{z}/{x}/{y}.jpg</httpPath>
            <format>jpg</format>
            <group>demo-zhongguo</group>
        </tc-tmsLayer>

        <tc-xyzLayer>
            <name>jingdian</name>
            <sortkey>1</sortkey>
            <loadMethod>http</loadMethod>
            <httpPath>http://wuhan.geoair.com.cn:9054/2024map/beijing/jingdian/{z}/{y}/{x}.png</httpPath>
            <format>png</format>
            <group>demo-jingdian</group>
        </tc-xyzLayer>
    </layers>

</gwcConfiguration>
