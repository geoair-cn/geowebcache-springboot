<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xmlns:context="http://www.springframework.org/schema/context"
       xmlns:tx="http://www.springframework.org/schema/tx"
       xsi:schemaLocation="http://www.springframework.org/schema/beans http://www.springframework.org/schema/beans/spring-beans-3.2.xsd
		http://www.springframework.org/schema/context http://www.springframework.org/schema/context/spring-context-3.2.xsd


		http://www.springframework.org/schema/tx http://www.springframework.org/schema/tx/spring-tx-3.2.xsd">

    <description>
        GeoAir的arcgiscache的相关配置类
    </description>

    <bean id="arcGisLayerConfigurationExtention"
          class="org.geowebcache.arcgis.layer.ArcGISLayerXMLConfigurationProvider"/>

    <bean id="TC-gwcArcGIGridsetConfigutation"
          class="cn.geoair.geoairteam.geowebcache.tianditu.layer.TC_ArcGISLayerXMLConfigurationProvider"/>

    <bean id="TC-arcGisLayerConfigurationExtention"
          class="cn.geoair.geoairteam.geowebcache.tianditu.layer.TC_ArcGISCacheGridsetConfiguration"/>

    <bean id="TC-CacheManger" class="cn.geoair.geoairteam.geowebcache.tianditu.utils.CacheManger">
    </bean>





    <!-- 扫描service层的Service注解 -->
    <context:component-scan base-package="cn.geoair.**"/>
</beans>
